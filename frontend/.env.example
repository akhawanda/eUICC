APP_NAME="ConnectX eUICC Simulator"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://euicc.connectxiot.com

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/euicc-frontend/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# Simulator endpoints (loopback — Nginx also exposes them at /api/es10 and /api/ipa)
EUICC_SIM_URL=http://127.0.0.1:8100
IPA_SIM_URL=http://127.0.0.1:8101

# Shared secret the sims present when calling /api/seed
SIM_SEED_TOKEN=replace-me-with-long-random-string

# Admin user seeded on first deploy
ADMIN_EMAIL=admin@connectxiot.com
ADMIN_PASSWORD=change-on-first-login
